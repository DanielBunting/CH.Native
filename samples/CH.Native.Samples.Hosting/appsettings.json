{
  "ClickHouse": {
    "Host": "localhost",
    "Port": 9000,
    "Database": "default",
    "Username": "demo_user",
    "Password": "demo",
    "Compress": true,
    "Pool": {
      "MaxPoolSize": 20,
      "MinPoolSize": 0
    }
  },
  "ClickHouse:Primary": {
    "Host": "localhost",
    "Port": 9000,
    "Database": "default",
    "Username": "default",
    "AuthMethod": "Jwt",
    "Pool": {
      "ConnectionLifetime": "00:05:00"
    }
  },
  "ClickHouse:Replica": {
    "Host": "localhost",
    "Port": 9000,
    "Database": "default",
    "Username": "demo_user",
    "Password": "demo"
  },
  "ClickHouse:Mtls": {
    "Host": "localhost",
    "TlsPort": 9440,
    "UseTls": true,
    "AllowInsecureTls": true,
    "Username": "cert_user",
    "AuthMethod": "TlsClientCertificate"
  },
  "ClickHouse:Ssh": {
    "Host": "localhost",
    "Port": 9000,
    "Username": "ssh_user",
    "AuthMethod": "SshKey"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
